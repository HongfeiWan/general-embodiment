# Local mission data copies, manifests, metadata, and generated reports are
# batch-specific artifacts. Keep mission docs in Git, but leave data local.
missions/*/*/manifest.jsonl
missions/*/*/*_summary.json
missions/*/*/raw/
missions/*/*/lerobot_v2/
missions/*/*/trimmed/
missions/*/*/trimmed_by_date/
missions/*/*/smooth/
missions/*/*/smooth_by_date/
missions/*/*/prepared_smooth/
missions/*/*/prepared_smooth_by_date/
missions/*/*/quality/
missions/*/*/smooth_quality/
missions/*/*/batch_quality/

__pycache__/
*.py[cod]

# Local Docker build artifacts. These can be regenerated from the local conda
# env and are too large for Git.
docker/dataprocess/dataprocess-conda-pack.tar.gz
